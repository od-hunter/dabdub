


# ========================
# App Configuration
# ========================
NODE_ENV=development # required: development | staging | production
PORT=3000 # required

# ========================
# Database
# ========================
DATABASE_URL=postgresql://user:password@host:5432/db # required

# ========================
# Redis
# ========================
REDIS_URL=redis://localhost:6379 # required

# ========================
# Auth
# ========================
JWT_ACCESS_SECRET=your_access_secret_here # required (min 32 chars)
JWT_REFRESH_SECRET=your_refresh_secret_here # required (min 32 chars)

# ========================
# Stellar
# ========================
STELLAR_NETWORK=testnet # required: testnet | public
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org # required
STELLAR_MASTER_SECRET=your_secret # required
STELLAR_WALLET_ENCRYPTION_KEY=32_characters_key_here # required (exactly 32 chars)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
ADMIN_SECRET_KEY=
USDC_SAC_ADDRESS=